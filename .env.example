# Required
TELEGRAM_BOT_TOKEN=replace-with-token
ALLOWED_TELEGRAM_USER_IDS=123456789

# SQLite is the default. PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://expense_bot:secret@db:5432/expenses
DATABASE_URL=sqlite+aiosqlite:///./data/expenses.db
TIMEZONE=Asia/Yekaterinburg
CURRENCY=RUB
MONTHLY_REPORT_HOUR=20
LOG_LEVEL=INFO
